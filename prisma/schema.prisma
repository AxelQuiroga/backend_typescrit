// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  username  String   @unique
  role      Role     @default(USER)
  posts     Post[]
  likes     Like[]
  comments  Comment[]  // ← Relación inversa: comentarios del usuario
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  likes     Like[]
  comments  Comment[]  // ← Relación inversa: comentarios del post
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id        String   @id @default(uuid())
  
  // Quién dio el like
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  
  // A qué post
  post      Post     @relation(fields: [postId], references: [id])
  postId    String
  
  createdAt DateTime @default(now())
 
  // Un usuario solo puede dar like una vez a un post
  @@unique([userId, postId])
  // Índice para buscar rápido likes de un post
  @@index([postId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  
  // Autor
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  
  // Post
  post      Post     @relation(fields: [postId], references: [id])
  postId    String
  
  // Jerarquía: comentario padre (null si es comentario raíz)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  parentId  String?
  
  // Respuestas anidadas
  replies   Comment[] @relation("CommentReplies")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  // Índices para queries eficientes
  @@index([postId])
  @@index([parentId])
  @@index([authorId])
}

enum Role {
  USER
  ADMIN
}